{
  "name": "easy-retro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "db:setup": "prisma generate --no-engine && prisma migrate deploy && prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "dev": "TZ=UTC next dev --turbopack",
    "lint:fix": "eslint --fix",
    "lint": "eslint",
    "start": "next start",
    "test:coverage:watch": "jest --coverage --watch",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test": "jest",
    "vercel-build": "npm run vercel-build:blank",
    "vercel-build:seed": "prisma generate --no-engine && prisma migrate deploy && prisma db push && npm run db:seed && next build",
    "vercel-build:blank": "prisma generate --no-engine && prisma migrate deploy && prisma db push && next build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.73",
    "@auth/prisma-adapter": "^2.11.2",
    "@floating-ui/react": "^0.27.19",
    "@hookform/resolvers": "^5.4.0",
    "@lambersond/3d-dice-core": "^0.4.0",
    "@lambersond/3d-dice-react": "^0.4.0",
    "@prisma/client": "6.19.3",
    "@prisma/extension-accelerate": "^3.0.1",
    "@react-pdf/renderer": "^4.5.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ably": "2.21.0",
    "ai": "^6.0.208",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "emoji-picker-react": "^4.19.1",
    "js-cookie": "^3.0.8",
    "lodash": "^4.18.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "stripe": "^20.4.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.10.38",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^17.6.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.4.1",
    "jest-mock-extended": "^4.0.1",
    "lint-staged": "^16.2.7",
    "node-mocks-http": "^1.17.2",
